{
  "name": "@golemworkers/relay-channel",
  "version": "1.0.58",
  "description": "Golem Workers relay-backed OpenClaw channel plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/golem-workers/golem-workers-openclaw-channel-plugin.git"
  },
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "install": {
      "npmSpec": "@golemworkers/relay-channel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12"
    },
    "compat": {
      "pluginApi": ">=1.0.0"
    },
    "build": {
      "openclawVersion": "2026.5.18"
    },
    "channel": {
      "id": "relay-channel",
      "label": "Relay Channel",
      "selectionLabel": "Relay Channel (Golem Workers)",
      "blurb": "Relay-backed OpenClaw channel plugin for Golem Workers agents."
    },
    "release": {
      "publishToNpm": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bundle:agent": "node ./scripts/build-agent-bundle.mjs",
    "deploy:agent": "node ./scripts/deploy-agent-bundle.mjs",
    "smoke:agent": "node ./scripts/smoke-cycle-via-admin.mjs",
    "smoke:agent:mock": "node ./scripts/smoke-cycle-via-admin.mjs --mock-relay",
    "validate:npm-publish": "node ./scripts/validate-npm-publish.mjs",
    "publish:npm-release": "node ./scripts/publish-npm-release.mjs",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.6.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.0",
    "ws": "^8.20.0"
  }
}
