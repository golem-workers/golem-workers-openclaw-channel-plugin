{
  "name": "golem-workers-openclaw-channel-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "relay-channel",
      "label": "Relay Channel",
      "blurb": "Relay-backed OpenClaw channel plugin."
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bundle:agent": "node ./scripts/build-agent-bundle.mjs",
    "deploy:agent": "node ./scripts/deploy-agent-bundle.mjs",
    "smoke:agent": "node ./scripts/smoke-cycle-via-admin.mjs",
    "smoke:agent:mock": "node ./scripts/smoke-cycle-via-admin.mjs --mock-relay",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "openclaw": "^2026.3.24",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.0"
  }
}
